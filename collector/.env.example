# Endpoint OTLP do Dynatrace — para o tenant fov31014
# Note: usa live.dynatrace.com (nao apps.dynatrace.com) e SEM /v1/traces no final
# (o exporter otlphttp adiciona a rota /v1/traces automaticamente)
DT_OTLP_ENDPOINT=https://fov31014.live.dynatrace.com/api/v2/otlp

# API Token classic (dt0c01.xxx) com scope:
#   - openTelemetryTrace.ingest
#   - metrics.ingest
# Gerar em: Access Tokens no tenant
DT_INGEST_TOKEN=dt0c01.SUBSTITUA_PELO_TOKEN_REAL
